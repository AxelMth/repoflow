{
  "name": "@axelmth/repoflow",
  "version": "0.0.1",
  "type": "module",
  "license": "MIT",
  "author": "Axel Mathieu-Le Gall <axel@example.com>",
  "description": "CLI to orchestrate multi-repository setups",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/axelmth/repoflow.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/axelmth/repoflow#readme",
  "bugs": {
    "url": "https://github.com/axelmth/repoflow/issues"
  },
  "keywords": [
    "meta-repository",
    "multi-repo",
    "monorepo",
    "ci-cd",
    "github-actions",
    "release",
    "automation"
  ],
  "bin": {
    "repoflow": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@axelmth/repoflow-core": "workspace:*",
    "@clack/prompts": "^0.9.0",
    "cli-table3": "^0.6.5",
    "commander": "^12.0.0",
    "execa": "^9.0.0",
    "picocolors": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0"
  }
}
