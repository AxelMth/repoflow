{
  "name": "@axelmth/repoflow-core",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "author": "Axel Mathieu-Le Gall <axel@example.com>",
  "description": "Core types, config loading, and repository abstractions for repoflow",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/axelmth/repoflow.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/axelmth/repoflow#readme",
  "bugs": {
    "url": "https://github.com/axelmth/repoflow/issues"
  },
  "keywords": [
    "meta-repository",
    "multi-repo",
    "monorepo",
    "ci-cd",
    "github-actions",
    "release",
    "automation"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "simple-git": "^3.27.0",
    "tsx": "^4.19.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.6.0"
  }
}
